# ─── O Cofre Digital — Configuração ────────────────────────────
APP_NAME=Cofre Digital
APP_KEY=troque-esta-chave-por-uma-string-aleatoria-segura-32chars

# Banco de dados
# Para SQLite (padrão, zero configuração):
DB_DRIVER=sqlite
DB_FILE=cofre.sqlite

# Para MySQL/PostgreSQL, troque pelo abaixo e ajuste:
# DB_DRIVER=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=cofre_digital
# DB_USER=root
# DB_PASS=

# Token
TOKEN_TTL_HOURS=24

# Timezone
TIMEZONE=America/Sao_Paulo
